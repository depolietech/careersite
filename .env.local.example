# Copy this file to .env.local and fill in your values

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev: SQLite
DATABASE_URL="file:./dev.db"
# Production (REQUIRED): Switch to PostgreSQL on Vercel/Supabase/Neon/Railway
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"
# REQUIRED — set to your production domain in production
NEXTAUTH_URL="http://localhost:3000"

# ─── App URL ───────────────────────────────────────────────────────────────────
# REQUIRED — used in email verification and password reset links
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Email ────────────────────────────────────────────────────────────────────
# OPTION 1 (Recommended): Resend HTTP API — more reliable than SMTP
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=""

# OPTION 2: SMTP via nodemailer (used only if RESEND_API_KEY is not set)
# For Resend SMTP: host=smtp.resend.com, port=465, secure=true, user=resend, pass=re_...
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""

# The "from" address — must be from your verified domain (e.g. noreply@equalhires.com)
SMTP_FROM="noreply@equalhires.com"

# Admin contact email — where contact form submissions are delivered
ADMIN_CONTACT_EMAIL="admin@equalhires.com"

# ─── OAuth Providers (all optional — app works without them) ──────────────────
# Google — https://console.cloud.google.com/
# Callback: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# LinkedIn — https://www.linkedin.com/developers/
# Callback: {NEXTAUTH_URL}/api/auth/callback/linkedin
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# Microsoft Entra ID — https://portal.azure.com/
# Callback: {NEXTAUTH_URL}/api/auth/callback/microsoft-entra-id
MICROSOFT_ENTRA_CLIENT_ID=""
MICROSOFT_ENTRA_CLIENT_SECRET=""
MICROSOFT_ENTRA_TENANT_ID="common"
