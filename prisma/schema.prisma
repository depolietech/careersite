generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  role          String    @default("JOB_SEEKER") // "JOB_SEEKER" | "EMPLOYER"
  recruiterType String?   // "COMPANY" | "AGENCY" — set only when role = EMPLOYER
  language      String    @default("en") // "en" | "fr-CA" | "es-MX"
  isPublicEmail Boolean   @default(false) // true if gmail/yahoo/hotmail etc.
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt              DateTime? // soft delete — set instead of destroying the row
  reinstateRequestedAt  DateTime? // set when user requests admin reinstatement of deleted account
  reinstateType         String?   // "restore" | "new_account" | "contact" — type of recovery request

  // Two-Factor Authentication
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String? // TOTP secret (base32)
  twoFactorMethod  String? // "totp" | "email"

  // Email Preferences (CAN-SPAM / CASL compliance)
  emailMarketing     Boolean @default(true)  // promotional + product updates
  emailJobAlerts     Boolean @default(true)  // new matching jobs
  emailAppUpdates    Boolean @default(true)  // application status changes
  // Security emails (password changed, 2FA) are ALWAYS sent — not toggleable

  accounts      Account[]
  sessions      Session[]

  // Role-specific profiles
  jobSeekerProfile  JobSeekerProfile?
  employerProfile   EmployerProfile?
  contractorProfile ContractorProfile?

  // Activity
  postedJobs     Job[]          @relation("PostedJobs")
  applications   Application[]
  interviews     Interview[]
  sentMessages   Message[]      @relation("SentMessages")
  notifications  Notification[]
  resumes        Resume[]

  // Security
  twoFactorBackupCodes TwoFactorBackupCode[]
  otpCodes             OtpCode[]

  // Reports filed by this user against recruiters
  reportsFiled     RecruiterReport[] @relation("ReporterReports")
  companyReviews   CompanyReview[]   @relation("ReviewerReviews")
  recruiterReviews RecruiterReview[] @relation("RecruiterReviewer")
}

model TwoFactorBackupCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  type      String   // "2fa_login" | "2fa_setup"
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Job Seeker ───────────────────────────────────────────────────────────────

model JobSeekerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Public — always visible to recruiters
  headline        String?
  summary         String?
  skills          String   // JSON array
  yearsExperience Int?
  jobType         String?  // "full-time" | "part-time" | "contract" | "remote"
  salaryMin       Int?
  salaryMax       Int?
  location        String?

  // RAW — masked until interview scheduled
  firstName   String
  lastName    String
  phone       String?
  photoUrl    String?
  photoSharingEnabled Boolean @default(false) // job seeker explicitly opts in to share photo with recruiters
  linkedinUrl String?
  githubUrl   String?

  workExperiences WorkExperience[]
  educations      Education[]
  certifications  Certification[]
  applications    Application[]

  importedFrom    String?   // "linkedin" | "indeed" | "pdf" | "manual"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model WorkExperience {
  id         String           @id @default(cuid())
  profileId  String
  profile    JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Always visible
  title        String
  description  String?
  skills       String   // JSON array
  roleCategory String?  // "Engineering" | "Design" | "Product" | "Marketing" | "Sales" | "Operations" | "Other"

  // RAW — masked (dates + company hidden; durationYears shown instead)
  company      String
  startDate    String   // "YYYY-MM"
  endDate      String?  // "YYYY-MM" — null if current
  current      Boolean  @default(false)

  // MASKED — pre-computed and always safe to show
  durationYears Float?
}

model Education {
  id         String           @id @default(cuid())
  profileId  String
  profile    JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Always visible
  degree     String
  field      String?

  // RAW — masked (school + years hidden; durationYears shown instead)
  institution  String
  startYear    Int
  endYear      Int?

  // MASKED — pre-computed and always safe to show
  durationYears Int?
}

model Certification {
  id         String           @id @default(cuid())
  profileId  String
  profile    JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name         String
  issuer       String
  dateObtained String?  // "YYYY-MM"
  expiryDate   String?  // "YYYY-MM"
}

// ─── Employer / Recruiter ─────────────────────────────────────────────────────

model EmployerProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName                String
  companyLegalName           String?
  companySize                String?   // "1-10" | "11-50" | "51-200" | "201-1000" | "1000+"
  industry                   String?
  website                    String?
  businessAddress            String?
  phone                      String?
  businessRegistrationNumber String?
  linkedinUrl                String?
  logoUrl                    String?
  description                String?
  location                   String?

  // Verification (Layer 2 — admin must approve before jobs can be posted)
  verificationStatus      String    @default("INCOMPLETE") // "INCOMPLETE" | "PENDING_REVIEW" | "APPROVED" | "REJECTED"
  verificationSubmittedAt DateTime?
  verificationNote        String?   // admin note (e.g. rejection reason)
  websiteCheckPassed      Boolean?  // auto-checked: website is reachable
  domainMatchPassed       Boolean?  // auto-checked: email domain matches website domain

  // Recruiter Audit — abuse detection
  interviewsScheduled  Int     @default(0)
  interviewsCancelled  Int     @default(0)
  trustScore           Float   @default(100)
  isBlocked            Boolean @default(false)

  postedJobs       Job[]
  reports          RecruiterReport[]
  companyReviews   CompanyReview[]
  recruiterReviews RecruiterReview[] @relation("RecruiterReviewsReceived")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ContractorProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  agencyName   String
  website      String?
  description  String?
  specialties  String  // JSON array

  managedJobs  Job[]   @relation("ManagedJobs")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Jobs ─────────────────────────────────────────────────────────────────────

model Job {
  id          String   @id @default(cuid())
  title       String
  description String
  location    String
  jobType     String   // "full-time" | "part-time" | "contract" | "remote"
  salaryMin   Int?
  salaryMax   Int?
  skills      String   // JSON array
  experience  Int?     // years required
  educationRequired   String?  // "high-school" | "college" | "bachelor" | "master" | "phd"
  certificateRequired String?  // free-text, e.g. "PMP, AWS Solutions Architect"
  status      String   @default("ACTIVE") // "DRAFT" | "ACTIVE" | "PAUSED" | "CLOSED"

  postedById          String?
  postedBy            User?              @relation("PostedJobs", fields: [postedById], references: [id])
  employerProfileId   String?
  employerProfile     EmployerProfile?   @relation(fields: [employerProfileId], references: [id])

  managedById         String?
  managedBy           ContractorProfile? @relation("ManagedJobs", fields: [managedById], references: [id])

  applications Application[]
  reports      RecruiterReport[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Recruiter Reports ────────────────────────────────────────────────────────

model RecruiterReport {
  id                String          @id @default(cuid())
  reporterId        String
  reporter          User            @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)
  employerProfileId String
  employerProfile   EmployerProfile @relation(fields: [employerProfileId], references: [id], onDelete: Cascade)
  jobId             String?
  job               Job?            @relation(fields: [jobId], references: [id], onDelete: SetNull)
  category          String          // "FAKE_JOB" | "SCAM" | "MISLEADING_ROLE" | "OTHER"
  description       String?
  status            String          @default("PENDING") // "PENDING" | "REVIEWED" | "DISMISSED"
  createdAt         DateTime        @default(now())
}

// ─── Company Reviews ──────────────────────────────────────────────────────────

model CompanyReview {
  id                String          @id @default(cuid())
  reviewerId        String
  reviewer          User            @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  employerProfileId String
  employerProfile   EmployerProfile @relation(fields: [employerProfileId], references: [id], onDelete: Cascade)
  rating            Int             // 1–5
  title             String
  body              String
  isAnonymous       Boolean         @default(true)
  createdAt         DateTime        @default(now())

  @@unique([reviewerId, employerProfileId])
}

// ─── Applications ─────────────────────────────────────────────────────────────

model Application {
  id        String           @id @default(cuid())
  jobId     String
  job       Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId String
  profile   JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  resumeId  String?
  resume    Resume?          @relation(fields: [resumeId], references: [id])

  status          String  @default("PENDING") // "PENDING" | "REVIEWING" | "SHORTLISTED" | "FORWARDED" | "INTERVIEW_SCHEDULED" | "REJECTED" | "OFFER_MADE" | "HIRED"
  coverLetter     String?
  revealed        Boolean @default(false)    // true once interview is scheduled
  profileSnapshot String?                    // immutable JSON snapshot of profile at submission time

  interview    Interview?
  conversation Conversation?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([jobId, userId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "APPLICATION_SUBMITTED" | "NEW_APPLICATION" | "STATUS_CHANGED"
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Resumes ──────────────────────────────────────────────────────────────────

model Resume {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  fileUrl   String
  fileName  String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  applications Application[]
}

// ─── Interviews ───────────────────────────────────────────────────────────────

model Interview {
  id            String      @id @default(cuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  scheduledById String
  scheduledBy   User        @relation(fields: [scheduledById], references: [id])

  scheduledAt  DateTime
  duration     Int      // minutes
  type         String   // "video" | "phone" | "in-person"
  meetingLink  String?
  notes        String?

  // Job seeker response
  seekerStatus              String  @default("PENDING") // "PENDING" | "ACCEPTED" | "REJECTED" | "RESCHEDULE_REQUESTED"
  seekerRejectionReason     String?
  seekerRescheduleProposedAt DateTime?
  seekerRescheduleNote      String?

  // Recruiter cancel reason
  cancelReason  String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime? @updatedAt
}

// ─── Admin Audit Log ──────────────────────────────────────────────────────────

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String   // "DELETE_USER" | "BLOCK_USER" | "UNBLOCK_USER" | "APPROVE_EMPLOYER" | "NOTE"
  targetId   String?  // userId or other entity id
  targetType String?  // "USER" | "JOB" | "APPLICATION"
  note       String?
  createdAt  DateTime @default(now())
}

// ─── Messaging ────────────────────────────────────────────────────────────────

model Conversation {
  id            String      @id @default(cuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])

  body      String
  createdAt DateTime @default(now())
}

// ─── Recruiter Reviews ────────────────────────────────────────────────────────

model RecruiterReview {
  id                String          @id @default(cuid())
  reviewerId        String
  reviewer          User            @relation("RecruiterReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  employerProfileId String
  employerProfile   EmployerProfile @relation("RecruiterReviewsReceived", fields: [employerProfileId], references: [id], onDelete: Cascade)
  applicationId     String?         // optional: link to specific application

  rating            Int             // 1–5 overall
  communication     Int             // 1–5
  professionalism   Int             // 1–5
  transparency      Int             // 1–5
  fairness          Int             // 1–5
  comment           String?

  isAnonymous       Boolean @default(true)
  createdAt         DateTime @default(now())

  @@unique([reviewerId, employerProfileId])
}
